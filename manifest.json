{
  "manifest_version": 3,
  "name": "WPP Team Tag",
  "description": "Prefixa mensagens do WhatsApp Web com o perfil selecionado.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "action": {
    "default_title": "WPP Team Tag",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_popup": "src/popup/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["src/content/page.ts"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["src/content/content.ts"],
      "run_at": "document_idle"
    }
  ]
}
